local function createToggle(page, icon, labelTxt, order, initState, onToggle)
    local card = Instance.new("Frame", page)
    card.Size = UDim2.new(1, 0, 0, 42)
    card.BackgroundColor3 = C.CARD
    card.BorderSizePixel = 0
    card.LayoutOrder = order
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 10)
    local cs = Instance.new("UIStroke", card)
    cs.Color = C.RED; cs.Thickness = 1; cs.Transparency = 0.78

    local lbl = Instance.new("TextLabel", card)
    lbl.Size = UDim2.new(0.65, 0, 1, 0)
    lbl.Position = UDim2.new(0, 12, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = icon .. "  " .. labelTxt
    lbl.TextColor3 = C.TEXT
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    local pill = Instance.new("TextButton", card)
    pill.Size = UDim2.new(0, 50, 0, 26)
    pill.Position = UDim2.new(1, -60, 0.5, -13)
    pill.BackgroundColor3 = C.INACTIVE
    pill.TextSize = 0
    pill.BorderSizePixel = 1
    pill.BorderColor3 = C.RED
    Instance.new("UICorner", pill).CornerRadius = UDim.new(0, 13)

    local circle = Instance.new("Frame", pill)
    circle.Size = UDim2.new(0, 22, 0, 22)
    circle.Position = UDim2.new(0, 2, 0.5, -11)
    circle.BackgroundColor3 = C.RED
    circle.BorderSizePixel = 0
    Instance.new("UICorner", circle).CornerRadius = UDim.new(0, 11)

    local state = initState or false

    local function applyState(s)
        TweenService:Create(pill, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {
            BackgroundColor3 = s and C.RED_DARK or C.INACTIVE
        }):Play()
        TweenService:Create(circle, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {
            Position = s and UDim2.new(0, 26, 0.5, -11) or UDim2.new(0, 2, 0.5, -11),
            BackgroundColor3 = s and C.GREEN or C.RED,
        }):Play()
    end

    applyState(state)

    pill.MouseButton1Click:Connect(function()
        state = not state
        applyState(state)
        if onToggle then onToggle(state) end
    end)

    return function() return state end
end

