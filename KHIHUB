local function createSlider(page, icon, labelTxt, minVal, maxVal, initVal, unit, order, callback)
    local card = Instance.new("Frame", page)
    card.Size = UDim2.new(1, 0, 0, 72)
    card.BackgroundColor3 = C.CARD
    card.BorderSizePixel = 0
    card.LayoutOrder = order
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 10)
    local cs = Instance.new("UIStroke", card)
    cs.Color = C.RED; cs.Thickness = 1; cs.Transparency = 0.75

    local iconLbl = Instance.new("TextLabel", card)
    iconLbl.Size = UDim2.new(0, 24, 0, 26)
    iconLbl.Position = UDim2.new(0, 10, 0, 4)
    iconLbl.BackgroundTransparency = 1
    iconLbl.Text = icon
    iconLbl.TextColor3 = C.RED
    iconLbl.Font = Enum.Font.GothamBold
    iconLbl.TextSize = 15

    local nameLbl = Instance.new("TextLabel", card)
    nameLbl.Size = UDim2.new(0.55, -40, 0, 26)
    nameLbl.Position = UDim2.new(0, 38, 0, 4)
    nameLbl.BackgroundTransparency = 1
    nameLbl.Text = labelTxt
    nameLbl.TextColor3 = C.TEXT
    nameLbl.Font = Enum.Font.GothamBold
    nameLbl.TextSize = 12
    nameLbl.TextXAlignment = Enum.TextXAlignment.Left

    local valLbl = Instance.new("TextLabel", card)
    valLbl.Size = UDim2.new(0.35, 0, 0, 26)
    valLbl.Position = UDim2.new(0.65, 0, 0, 4)
    valLbl.BackgroundTransparency = 1
    valLbl.Text = initVal .. unit
    valLbl.TextColor3 = C.RED
    valLbl.Font = Enum.Font.GothamBold
    valLbl.TextSize = 13
    valLbl.TextXAlignment = Enum.TextXAlignment.Right

    -- Track background
    local trackBG = Instance.new("Frame", card)
    trackBG.Size = UDim2.new(1, -20, 0, 8)
    trackBG.Position = UDim2.new(0, 10, 0, 46)
    trackBG.BackgroundColor3 = C.INACTIVE
    trackBG.BorderSizePixel = 0
    Instance.new("UICorner", trackBG).CornerRadius = UDim.new(0, 4)

    -- Track fill
    local trackFill = Instance.new("Frame", trackBG)
    local initFrac = (initVal - minVal) / (maxVal - minVal)
    trackFill.Size = UDim2.new(initFrac, 0, 1, 0)
    trackFill.BackgroundColor3 = C.RED
    trackFill.BorderSizePixel = 0
    Instance.new("UICorner", trackFill).CornerRadius = UDim.new(0, 4)

    -- Knob
    local knob = Instance.new("Frame", trackBG)
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = UDim2.new(initFrac, -8, 0.5, -8)
    knob.BackgroundColor3 = C.WHITE
    knob.BorderSizePixel = 0
    Instance.new("UICorner", knob).CornerRadius = UDim.new(0, 8)
    local ks = Instance.new("UIStroke", knob)
    ks.Color = C.RED; ks.Thickness = 2

    local currentVal = initVal
    local dragging = false

    local function updateSlider(inputPos)
        local trackAbsPos = trackBG.AbsolutePosition.X
        local trackAbsSize = trackBG.AbsoluteSize.X
        local frac = math.clamp((inputPos - trackAbsPos) / trackAbsSize, 0, 1)
        currentVal = math.round(minVal + frac * (maxVal - minVal))
        trackFill.Size = UDim2.new(frac, 0, 1, 0)
        knob.Position = UDim2.new(frac, -8, 0.5, -8)
        valLbl.Text = currentVal .. unit
        if callback then callback(currentVal) end
    end

    trackBG.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            updateSlider(input.Position.X)
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(input.Position.X)
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    return function() return currentVal end
end

