	pcall(function()
		-- Keep running state active to bypass fatigue
		humanoid:SetStateEnabled(Enum.HumanoidStateType.Running, true)
	end)
end)

-- SPEED BOOST SYSTEM - APPLY ONLY WHEN ENABLED
local lastSpeedApply = 0
RunService.Heartbeat:Connect(function()
	if not character or not humanoid or not speedEnabled then return end
	
	lastSpeedApply = lastSpeedApply + 1
	if lastSpeedApply >= 5 then
		lastSpeedApply = 0
		pcall(function()
			humanoid.WalkSpeed = currentSpeedValue
		end)
	end
end)

local function performRegularShot()
	if not canShoot or not getAutoShootOn() or isShooting then return end

	canShoot = false
	isShooting = true

	VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
	task.wait(shootDuration / 1000)
	VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)

	isShooting = false
	canShoot = true
end

local function performFadeShot()
	if not canShoot or not getAutoShootOn() or not getFadeTimingOn() or isShooting then return end

	canShoot = false
	isShooting = true

	task.wait(fadeTimingDelay / 1000)

	VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
	task.wait(fadeShotDuration / 1000)
	VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)

	isShooting = false
	canShoot = true
end

UIS.InputBegan:Connect(function(input, gameProcessed)
	if input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then
		isShiftHeld = true
	end

	if input.KeyCode == Enum.KeyCode.ButtonR2 then
		isRTHeld = true
	end

	if gameProcessed then return end

	if input.KeyCode == Enum.KeyCode.E or input.KeyCode == Enum.KeyCode.ButtonX then
		if isShiftHeld or isRTHeld then
			performFadeShot()
		else
			performRegularShot()
		end
	end
end)

UIS.InputEnded:Connect(function(input, gameProcessed)
	if input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then
		isShiftHeld = false
	end

	if input.KeyCode == Enum.KeyCode.ButtonR2 then
		isRTHeld = false
	end
end)

