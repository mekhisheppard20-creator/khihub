local function performRegularShot()
    if not canShoot or not autoShootOn or isShooting then return end
    canShoot = false; isShooting = true
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(shootDuration / 1000)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
    isShooting = false; canShoot = true
end

local function performFadeShot()
    if not canShoot or not autoShootOn or not fadeTimingOn or isShooting then return end
    canShoot = false; isShooting = true
    task.wait(fadeTimingDelay / 1000)
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(fadeShotDuration / 1000)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
    isShooting = false; canShoot = true
end

UIS.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then isShiftHeld = true end
    if input.KeyCode == Enum.KeyCode.ButtonR2 then isRTHeld = true end
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.E or input.KeyCode == Enum.KeyCode.ButtonX then
        -- Lift FIRST before anything else fires, hold in air for 3 seconds
        if antiContestOn and character and hrp then
            hrp.CFrame = hrp.CFrame + Vector3.new(0, 5, 0)
            local floatConn
            local elapsed = 0
            local floatY = hrp.Position.Y
            floatConn = RunService.Heartbeat:Connect(function(dt)
                elapsed = elapsed + dt
                if elapsed >= 3 or not hrp or not antiContestOn then
                    if floatConn then floatConn:Disconnect() end
                    return
                end
                -- Keep Y locked at float height
                local p = hrp.Position
                hrp.CFrame = CFrame.new(p.X, floatY, p.Z) * (hrp.CFrame - hrp.CFrame.Position)
                hrp.AssemblyLinearVelocity = Vector3.new(
                    hrp.AssemblyLinearVelocity.X,
                    0,
                    hrp.AssemblyLinearVelocity.Z
                )
            end)
        end
        if isShiftHeld or isRTHeld then performFadeShot()
        else performRegularShot() end
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then isShiftHeld = false end
    if input.KeyCode == Enum.KeyCode.ButtonR2 then isRTHeld = false end
end)

