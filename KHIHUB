-- INFINITE STAMINA - BLOCK STAMINA DRAIN EVENT
RunService.Heartbeat:Connect(function()
	if not character or not humanoid then return end
	
	-- Restore humanoid health to max
	humanoid.Health = humanoid.MaxHealth
	
	-- Find and disable any humanoid state for fatigue/climbing
	pcall(function()
		humanoid:SetStateEnabled(Enum.HumanoidStateType.Climbing, true)
		humanoid:SetStateEnabled(Enum.HumanoidStateType.Running, true)
	end)
	
	-- Search and set all stamina values to max
	local function maxStamina(obj)
		if not obj then return end
		pcall(function()
			-- Check for stamina attribute
			local staminaAttr = obj:GetAttribute("Stamina")
			if staminaAttr and typeof(staminaAttr) == "number" then
				obj:SetAttribute("Stamina", 100)
			end
			
			-- Check for max stamina
			local maxStaminaAttr = obj:GetAttribute("MaxStamina")
			if maxStaminaAttr then
				obj:SetAttribute("Stamina", maxStaminaAttr)
			end
			
			-- Check all values
			for _, child in pairs(obj:GetChildren()) do
				local name = string.lower(child.Name)
				if (child:IsA("NumberValue") or child:IsA("IntValue")) and 
					(name:find("stamina") or name:find("energy") or name:find("tired")) then
					child.Value = 100
				end
			end
		end)
		
		-- Recurse
		for _, child in pairs(obj:GetChildren()) do
			maxStamina(child)
		end
	end
	
	maxStamina(character)
end)

-- OVERRIDE RUNNING STATE TO PREVENT STAMINA DRAIN
RunService.Heartbeat:Connect(function()
