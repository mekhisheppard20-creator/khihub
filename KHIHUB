-- ============= CORE: DRIBBLE GLIDE =============
local dribbleCooldown = false
local glideActive = false
local glideTimeLeft = 0
local glideDirection = Vector3.new(0, 0, 0)

local dribbleKeys = {
    Enum.KeyCode.DPadLeft,
    Enum.KeyCode.DPadRight,
    Enum.KeyCode.DPadUp,
    Enum.KeyCode.DPadDown,
    Enum.KeyCode.Z,
    Enum.KeyCode.X,
    Enum.KeyCode.C,
    Enum.KeyCode.V,
}

local function fireGlide()
    if not dribbleGlideOn or not character or not hrp then return end
    if dribbleCooldown then return end
    dribbleCooldown = true

    local lookDir = hrp.CFrame.LookVector
    glideDirection = Vector3.new(lookDir.X, 0, lookDir.Z).Unit
    glideActive = true
    glideTimeLeft = 0.55 -- how long the glide lasts in seconds

    task.delay(0.6, function()
        dribbleCooldown = false
    end)
end

-- Smooth glide applied each frame while active
RunService.Heartbeat:Connect(function(dt)
    if not glideActive or not character or not hrp then return end
    glideTimeLeft = glideTimeLeft - dt
    if glideTimeLeft <= 0 then
        glideActive = false
        return
    end

    -- Ease off over time: full force at start, tapering to 0
    local progress = glideTimeLeft / 0.55
    local forceMag = dribbleGlideForce * progress * dt * 6
    local vel = hrp.AssemblyLinearVelocity
    hrp.AssemblyLinearVelocity = Vector3.new(
        vel.X + glideDirection.X * forceMag,
        vel.Y,
        vel.Z + glideDirection.Z * forceMag
    )
end)

UIS.InputBegan:Connect(function(input, gpe)
    for _, key in ipairs(dribbleKeys) do
        if input.KeyCode == key then
            fireGlide()
            return
        end
    end
end)

