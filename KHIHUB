	toggleButton.MouseButton1Click:Connect(function()
		state = not state

		local bgTween = TweenService:Create(
			toggleButton,
			TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ BackgroundColor3 = state and Color3.fromRGB(0, 180, 100) or Color3.fromRGB(50, 50, 70) }
		)

		local positionTween = TweenService:Create(
			toggleCircle,
			TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ Position = state and UDim2.new(0, 24, 0.5, -12) or UDim2.new(0, 2, 0.5, -12) }
		)

		local circleTween = TweenService:Create(
			toggleCircle,
			TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ BackgroundColor3 = state and Color3.fromRGB(0, 200, 255) or Color3.fromRGB(150, 150, 180) }
		)

		bgTween:Play()
		positionTween:Play()
		circleTween:Play()
	end)

	return function()
		return state
	end
end

local getAutoShootOn = createToggle("Auto-Shoot", "🎯", 280)
local getFadeTimingOn = createToggle("Fade Timing", "🌫️", 335)
local getSpeedBoostOn = createToggle("Speed Boost", "💨", 390)

RunService.RenderStepped:Connect(function()
	if character and humanoid and hrp then
		local velocity = hrp.AssemblyLinearVelocity.Magnitude
		isRunning = velocity > 5
	end
end)

-- STAMINA RESTORE - Ultra aggressive, every single frame
RunService.Heartbeat:Connect(function()
	if not character then return end
	
	local function deepRestore(obj, depth)
		if not obj or depth > 10 then return end
		
		pcall(function()
			local objName = tostring(obj.Name):lower()
			
			-- NumberValue restoration
			if obj:IsA("NumberValue") then
				if objName:find("stamina") or objName:find("energy") or objName:find("stam") then
					obj.Value = 100
				end
			end
			
			-- Attribute restoration
			local stamAttr = obj:GetAttribute("Stamina")
			if stamAttr then obj:SetAttribute("Stamina", 100) end
			
			local energyAttr = obj:GetAttribute("Energy")
			if energyAttr then obj:SetAttribute("Energy", 100) end
		end)
		
		-- Recursively check all children
		for _, child in pairs(obj:GetChildren()) do
			deepRestore(child, depth + 1)
		end
	end
	
	deepRestore(character, 0)
end)

-- ============= SPEED BOOST SYSTEM - WALK SPEED ONLY =============
RunService.Heartbeat:Connect(function()
	if character and humanoid and hrp and getSpeedBoostOn() then
		pcall(function()
			humanoid.WalkSpeed = walkSpeed * speedMultiplier
		end)
	else
		pcall(function()
			humanoid.WalkSpeed = defaultWalkSpeed
		end)
	end
end)

local function performRegularShot()
	if not canShoot or not getAutoShootOn() or isShooting then return end

	canShoot = false
	isShooting = true

	VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
	task.wait(shootDuration / 1000)
	VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)

	isShooting = false
	canShoot = true
end

local function performFadeShot()
	if not canShoot or not getAutoShootOn() or not getFadeTimingOn() or isShooting then return end

	canShoot = false
	isShooting = true

	task.wait(fadeTimingDelay / 1000)

	VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
	task.wait(fadeShotDuration / 1000)
	VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)

	isShooting = false
	canShoot = true
end

UIS.InputBegan:Connect(function(input, gameProcessed)
	if input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then
		isShiftHeld = true
	end

	if input.KeyCode == Enum.KeyCode.ButtonR2 then
		isRTHeld = true
	end

	if gameProcessed then return end

	if input.KeyCode == Enum.KeyCode.E or input.KeyCode == Enum.KeyCode.ButtonX then
		if isShiftHeld or isRTHeld then
			performFadeShot()
		else
			performRegularShot()
		end
	end
end)

UIS.InputEnded:Connect(function(input, gameProcessed)
	if input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then
		isShiftHeld = false
	end

	if input.KeyCode == Enum.KeyCode.ButtonR2 then
		isRTHeld = false
	end
end)

player.CharacterAdded:Connect(function(newCharacter)
	character = newCharacter
	humanoid = character:WaitForChild("Humanoid")
	hrp = character:WaitForChild("HumanoidRootPart")
	canShoot = true
	isShooting = false
end)
