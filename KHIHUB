    inputBox.PlaceholderText = tostring(initVal)
    inputBox.Font = Enum.Font.GothamBold
    inputBox.TextSize = 13
    inputBox.BorderSizePixel = 1
    inputBox.BorderColor3 = C.RED
    inputBox.Text = tostring(initVal)
